# Kalshi API (v2, RSA-signed). Generate a key pair in Kalshi account settings.
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=/absolute/path/to/kalshi_private_key.pem

# LLM providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional: Brave search API for the research toolbox (falls back to DuckDuckGo HTML)
BRAVE_API_KEY=

# Optional: push alerts via ntfy.sh (just pick a unique topic name)
NTFY_TOPIC=
